# =============================================================================
# Demonopol TaaS — environment variables
# =============================================================================
# Copy this file to .env.local for local development.
# Set production values in Vercel project settings.
# Never commit .env.local. Never log these values.
# =============================================================================

# ---- App ----
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Demonopol Tokenization-as-a-Service"
NODE_ENV="development"

# ---- Database (Supabase / Neon Postgres) ----
DATABASE_URL=""
DIRECT_URL=""

# ---- Supabase (auth + storage for PDFs) ----
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="reports"

# ---- Anthropic (auto-report generation) ----
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-7"
ANTHROPIC_MAX_TOKENS="1500"

# ---- Stripe (Diagnostic payments) ----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_DIAGNOSTIC_PRICE_ID=""

# ---- Cal.com (Diagnostic booking) ----
CAL_API_KEY=""
CAL_WEBHOOK_SECRET=""
NEXT_PUBLIC_CAL_LINK="demonopol/diagnostic"

# ---- Resend (transactional email) ----
RESEND_API_KEY=""
EMAIL_FROM="Demonopol <issuers@demonopol.com>"
EMAIL_REPLY_TO="issuers@demonopol.com"
EMAIL_INTERNAL_NOTIFY="founder@demonopol.com"

# ---- Slack (lead notifications) ----
SLACK_WEBHOOK_LEADS=""

# ---- Sanity CMS (bilingual content) ----
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
SANITY_API_TOKEN=""
SANITY_STUDIO_PREVIEW_SECRET=""

# ---- Cloudflare Turnstile (form bot protection) ----
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ---- Upstash Redis (rate limiting) ----
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---- Analytics & error tracking ----
# Plausible and Sentry deferred (paid services). Vercel runtime logs and
# Vercel Web Analytics (free) are sufficient for V1. Re-enable later if
# we need richer error capture or product analytics.

# ---- Demonopol ecosystem (shared) ----
NEXT_PUBLIC_DEMONOPOL_APP_URL="https://demonopol.com"
NEXT_PUBLIC_DEMONOPOL_DOCS_URL="https://docs.demonopol.com"
NEXT_PUBLIC_DEMONOPOL_MEDIUM_URL="https://medium.com/@demonopolrwa"

# ---- Feature flags ----
FEATURE_MONO_PAYMENT="false"        # V2 — accept $MONO on Sui
FEATURE_VN_LOCALE="true"            # Vietnamese mirror
FEATURE_INSIGHTS="true"              # /insights blog
