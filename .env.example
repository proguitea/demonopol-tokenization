# =============================================================================
# Demonopol TaaS — environment variables (V1-essential cut)
# =============================================================================
# Copy this file to .env.local for local development.
# Set production values in Vercel project settings.
# Never commit .env.local. Never log these values.
# =============================================================================

# ---- App ----
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Demonopol Tokenization-as-a-Service"
NODE_ENV="development"

# ---- Resend (form-to-email notifications) ----
# Without RESEND_API_KEY the action logs to the server console — submissions
# are never silently dropped, but no email is sent.
RESEND_API_KEY=""
EMAIL_FROM="Demonopol <tokenize@demonopol.com>"
EMAIL_INTERNAL_NOTIFY="tokenize@demonopol.com"

# ---- Stripe (Diagnostic payments — Week 4) ----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_DIAGNOSTIC_PRICE_ID=""

# ---- Cal.com (Diagnostic booking — Week 4) ----
NEXT_PUBLIC_CAL_LINK="demonopol/diagnostic"

# ---- IP-hash salt (privacy) ----
# Used so the founder can spot-detect duplicate submitters without ever
# storing the raw IP. Any random string works.
IP_HASH_SALT=""

# ---- Demonopol ecosystem (shared) ----
NEXT_PUBLIC_DEMONOPOL_APP_URL="https://demonopol.com"

# =============================================================================
# Deferred from V1 (re-enable when volume justifies the spend / complexity)
# =============================================================================
#
# Originally specced but cut for the V1-essential build (2026-04-27):
#
#   - Postgres / Supabase           : DB persistence, replaced by form-to-email
#   - Anthropic API                  : auto-report PDF generation
#   - Cloudflare Turnstile           : bot protection (honeypot is enough at V1 volume)
#   - Upstash Redis                  : rate limiting (Vercel handles DDoS at the edge)
#   - Slack webhook                  : high-score notifications (email is enough)
#   - Sanity CMS                     : Insights blog (use MDX in-repo for V1)
#   - Plausible / Sentry             : analytics + error tracking (deferred earlier)
#
# All references removed from code. Re-add when you reach the volume that
# justifies them, and add their env vars back to this file at that point.
